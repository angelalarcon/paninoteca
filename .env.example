# Variables de entorno para la integración Verifactu.
#
# Para desarrollo local con `netlify dev`: copia este archivo a `.env`
# (sin sufijo) en la raíz del repo. Está en .gitignore para no subirlo.
#
# Para producción: configúralas en Netlify → Site settings →
# Environment variables (o `netlify env:set ...`).

# API key de Verifacti — empieza por vf_test_ (sandbox) o vf_prod_ (producción).
# Cada NIF tiene su propia API key. Se obtiene en https://app.verifacti.com
VERIFACTI_API_KEY=vf_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL base de la API. Solo cambiar si Verifacti te indica otro endpoint.
VERIFACTI_BASE_URL=https://api.verifacti.com
